{
  "name": "@web-auto/webauto",
  "version": "0.1.20",
  "type": "module",
  "bin": {
    "webauto": "bin/webauto.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "modules/",
    "runtime/",
    "scripts/",
    "services/",
    "apps/webauto/",
    "!dist/**/*.map",
    "!dist/**/__tests__/**",
    "!dist/**/tests/**",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!modules/**/node_modules/**",
    "!modules/**/__tests__/**",
    "!modules/**/tests/**",
    "!modules/**/*.test.*",
    "!modules/**/*.spec.*",
    "!modules/**/*.map",
    "!services/**/__tests__/**",
    "!services/**/tests/**",
    "!services/**/*.test.*",
    "!services/**/*.spec.*",
    "!services/**/*.map"
  ],
  "dependencies": {
    "@web-auto/camo": "0.2.0",
    "ajv": "^8.18.0",
    "esbuild-register": "^3.6.0",
    "iconv-lite": "^0.6.3",
    "linkedom": "^0.18.12",
    "minimist": "^1.2.8",
    "node-fetch": "^2.7.0",
    "sharp": "^0.33.5",
    "undici": "^7.22.0",
    "ws": "^8.19.0"
  },
  "bundleDependencies": [
    "@web-auto/camo"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall-resources.mjs",
    "prepack": "npm run build",
    "start:mcp:browser": "npx @browsermcp/mcp@latest",
    "build": "npm run prebuild && npm run build:services && npm run self-check:post-build && npm run ui:test",
    "build:services": "tsc -p tsconfig.services.json",
    "self-check:post-build": "node scripts/self-check.mjs --quick --post-build",
    "start": "node dist/apps/webauto/server.js",
    "start:autoscript": "WEBAUTO_RUNTIME_MODE=autoscript WEBAUTO_BROWSER_PROVIDER=camo node dist/apps/webauto/server.js",
    "start:unified": "WEBAUTO_RUNTIME_MODE=unified node dist/apps/webauto/server.js",
    "test:services": "node runtime/infra/utils/scripts/test-services.mjs",
    "check:modules": "echo \"Module checks skipped\"",
    "check:ts": "tsc --noEmit -p tsconfig.services.json",
    "test:modules:unit": "npx tsx --test $(find modules -name \"*.test.ts\" -o -name \"*.test.mts\" 2>/dev/null | tr \"\\n\" \" \")",
    "test:webauto:schedule:unit": "node --test tests/unit/webauto/schedule-store.test.mjs tests/unit/webauto/schedule-cli.test.mjs",
    "test:webauto:ui-cli:unit": "node --test tests/unit/webauto/ui-cli-command.test.mjs",
    "test:webauto:test-cli:unit": "node --test tests/unit/webauto/test-cli-command.test.mjs",
    "test:webauto:install:unit": "node --test tests/unit/webauto/xhs-install.test.mjs",
    "test:e2e-ui": "npx vitest --config tests/e2e-ui/vitest.config.ts",
    "test:e2e-ui:l0": "npx vitest --config tests/e2e-ui/vitest.config.ts tests/e2e-ui/contracts/api.test.ts",
    "test:e2e-ui:l1": "npx vitest --config tests/e2e-ui/vitest.config.ts tests/e2e-ui/controls/full-cover.test.ts",
    "test:e2e-ui:l2": "npx vitest --config tests/e2e-ui/vitest.config.ts tests/e2e-ui/flows/task-run.test.ts",
    "test:e2e-ui:l3": "npx vitest --config tests/e2e-ui/vitest.config.ts tests/e2e-ui/stability/restart.test.ts",
    "test:xhs:collect": "node scripts/test/xhs-collect-smoke.mjs",
    "test:webauto:schedule:coverage": "c8 --reporter=text --reporter=text-summary --check-coverage --lines 85 --functions 85 --branches 60 --statements 85 --include apps/webauto/entry/lib/schedule-store.mjs --include apps/webauto/entry/schedule.mjs node --test tests/unit/webauto/schedule-store.test.mjs tests/unit/webauto/schedule-cli.test.mjs",
    "test:ci": "npm test",
    "coverage:ci": "node scripts/test/run-coverage.mjs",
    "build:release": "node bin/webauto.mjs build:release",
    "version:bump": "node scripts/bump-version.mjs patch",
    "version:bump:minor": "node scripts/bump-version.mjs minor",
    "version:bump:major": "node scripts/bump-version.mjs major",
    "test": "npm run check:modules && npm run check:ts && npm run test:modules:unit && npm run test:webauto:schedule:unit && npm run test:webauto:ui-cli:unit && npm run test:webauto:test-cli:unit && npm run test:webauto:install:unit && npm run test:services:unit",
    "cli:session-manager": "tsx modules/session-manager/src/cli.ts",
    "cli:logging": "tsx modules/logging/src/cli.ts",
    "cli:operations": "tsx modules/operations/src/cli.ts",
    "ui:test": "echo 'UI tests migrated to runtime/infra/utils/scripts/development/'",
    "ui:test:driver": "node runtime/infra/utils/scripts/development/eval-in-session.mjs",
    "ui:state": "node runtime/infra/utils/scripts/development/highlight-search-containers.mjs",
    "service:kill-port": "node runtime/infra/utils/scripts/service/kill-port.mjs",
    "browser:camoufox:install": "python3 -m camoufox remove && python3 -m camoufox fetch",
    "test:state:coverage": "c8 --reporter=text --reporter=lcov tsx --test modules/state/src/*.test.ts",
    "prebuild": "node scripts/self-check.mjs --quick && node scripts/check-root-layout.mjs && node scripts/check-legacy-refs.mjs && node scripts/check-docs-legacy.mjs && node scripts/check-untracked-sources.mjs && node scripts/check-sub-dist.mjs && node scripts/check-max-lines.mjs --limit=500 --disabled",
    "self-check": "node scripts/self-check.mjs",
    "self-check:quick": "node scripts/self-check.mjs --quick",
    "self-check:fix": "node scripts/self-check.mjs --fix",
    "test:services:unit": "npx tsx --test $(find services -name \"*.test.ts\" -o -name \"*.test.mts\" 2>/dev/null | tr \"\\n\" \" \")",
    "test:webauto:inspection:coverage": "c8 --reporter=text --reporter=text-summary --check-coverage --lines 90 --functions 90 --branches 80 --statements 90 --include apps/webauto/entry/lib/inspection-scheduler.mjs node --test tests/unit/webauto/inspection-scheduler.test.mjs"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.10.13",
    "@types/ws": "^8.18.1",
    "c8": "^10.1.0",
    "camoufox": "^0.1.19",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
